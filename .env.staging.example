# ---------------------------------------------------------------------------
# .env.staging.example — profile for a staging WHMCS instance.
# Copy to `.env.staging` (gitignored). Activated by MCP_ENV=staging.
# Staging should mirror production posture: https only, no WHMCS_ALLOW_HTTP.
# ---------------------------------------------------------------------------

MCP_ENV=staging

WHMCS_API_URL=https://staging-whmcs.example.com
WHMCS_IDENTIFIER=
WHMCS_SECRET=
WHMCS_ACCESS_KEY=

MCP_AUTH_TOKEN=

MCP_ACCESS_MODE=admin
MCP_ALLOWED_CLIENT_IDS=

# Keep staging read_only unless deliberately testing writes against staging.
MCP_MODE=read_only

MCP_RATE_LIMIT=10
MCP_DEBUG=false
MCP_MAX_PAGE_SIZE=100
MCP_TOOL_ALLOWLIST=
MCP_LARGE_REFUND_THRESHOLD=1000
