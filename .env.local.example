# ---------------------------------------------------------------------------
# .env.local.example — profile for the local dockerized WHMCS dev/test stack
# (docker-compose.whmcs-test.yml). Copy to `.env.local` and fill in the API
# credentials you create inside the local WHMCS admin.
#
# Activated by MCP_ENV=local: src/config.ts layers `.env.local` on top of the
# base `.env` (env-specific values win; real exported env wins over both).
# `.env.local` is gitignored.
# ---------------------------------------------------------------------------

MCP_ENV=local

# 8.13 leg (matches current prod major). 9.0 leg = http://localhost:8890
WHMCS_API_URL=http://localhost:8813

# Local WHMCS is plain http on localhost. SEC-005 rejects non-https unless
# this is explicitly set — intentional and scoped to the local profile only.
WHMCS_ALLOW_HTTP=true

# Create these in the local WHMCS admin:
#   Admin → System Settings → API Credentials → Generate New API Credential
#   (Roles: full admin for dev; leave "API IP Access Restriction" blank)
WHMCS_IDENTIFIER=
WHMCS_SECRET=
WHMCS_ACCESS_KEY=

# Optional shared-secret for the MCP itself (leave blank for local).
MCP_AUTH_TOKEN=

MCP_ACCESS_MODE=admin
MCP_ALLOWED_CLIENT_IDS=

# Start read_only. The local WHMCS is disposable (npm run whmcs:test:reset),
# so `simulate` or `full` are SAFE here for exercising write tools.
MCP_MODE=read_only

MCP_RATE_LIMIT=10
MCP_DEBUG=true
MCP_MAX_PAGE_SIZE=100
MCP_TOOL_ALLOWLIST=
MCP_LARGE_REFUND_THRESHOLD=1000
