{
  "name": "whmcs-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for WHMCS administration via AI agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/normalizers.test.ts tests/errors.test.ts tests/rateLimiter.test.ts tests/tools/",
    "test:integration": "vitest run tests/integration.test.ts",
    "debug:domain-whois": "tsx scripts/debug-domain-whois.ts",
    "curl:domain-whois": "tsx scripts/curl-domain-whois.ts",
    "test:coverage": "vitest run --coverage",
    "precommit": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "docker:build": "docker build -t whmcs-mcp-server .",
    "docker:run": "docker-compose up -d",
    "whmcs:test:source": "bash deploy/whmcs-test/stage-source.sh",
    "whmcs:test:licenses": "bash deploy/whmcs-test/stage-licenses.sh",
    "whmcs:test:up": "docker compose -f docker-compose.whmcs-test.yml up -d",
    "whmcs:test:ps": "docker compose -f docker-compose.whmcs-test.yml ps",
    "whmcs:test:logs": "docker compose -f docker-compose.whmcs-test.yml logs -f",
    "whmcs:test:license-install": "bash deploy/whmcs-test/install-license.sh",
    "whmcs:test:fixup": "bash deploy/whmcs-test/post-install-fixup.sh",
    "whmcs:test:snapshot": "bash deploy/whmcs-test/snapshot.sh",
    "whmcs:test:reset": "bash deploy/whmcs-test/reset.sh",
    "whmcs:test:pull-prod": "bash deploy/whmcs-test/pull-prod-db.sh",
    "whmcs:test:seed-prod": "bash deploy/whmcs-test/seed-from-prod.sh",
    "whmcs:test:upgrade9": "bash deploy/whmcs-test/whmcs9-upgrade.sh",
    "whmcs:test:bootstrap": "bash deploy/whmcs-test/bootstrap-from-source-snapshot.sh",
    "whmcs:test:down": "docker compose -f docker-compose.whmcs-test.yml down -v",
    "whmcs:test:replicate-cred": "bash deploy/whmcs-test/replicate-cred.sh",
    "mcp:test:production-program": "node scripts/mcp-production-test-program.mjs"
  },
  "keywords": [
    "mcp",
    "whmcs",
    "ai",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "dotenv": "^17.2.3",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^25.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.1.8"
  }
}
