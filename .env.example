# WHMCS API Configuration
WHMCS_API_URL=https://your-whmcs-domain.com
WHMCS_IDENTIFIER=your_api_identifier
WHMCS_SECRET=your_api_secret
WHMCS_ACCESS_KEY=
# Set to true only to allow an http:// WHMCS_API_URL (not recommended; credentials sent in clear)
WHMCS_ALLOW_HTTP=false

# MCP Server Configuration
# Environment profile: local | staging | production (default: production).
# Selects which .env.<MCP_ENV> file is layered on top of this base .env.
# See .env.local.example for the local dockerized-WHMCS profile and
# docs/local-whmcs-testing.md for the full local dev/test workflow.
MCP_ENV=production
MCP_MODE=read_only
MCP_ACCESS_MODE=admin
MCP_ALLOWED_CLIENT_IDS=
MCP_AUTH_TOKEN=
MCP_RATE_LIMIT=10
MCP_DEBUG=false
MCP_MAX_PAGE_SIZE=100
MCP_TOOL_ALLOWLIST=
MCP_LARGE_REFUND_THRESHOLD=1000

# ── Phase B governance (opt-in, backward compatible) ──────────────────────────
# OFF (default) => existing legacy tool/resource output is byte-identical
# (no app/test breakage). ON => read output is routed through the
# consumer-aware projection boundary. Production stays read-only either way.
MCP_GOVERNANCE_ENABLED=false
# Allow the deliberate anonymous llm_safe_summary fallback for unknown/no-token
# callers. NEVER grants a privileged profile; in production an explicit
# `anonymous` registry entry is still required. Default false.
MCP_ALLOW_ANON_LLM=false
# Consumer registry (JSON array). Real per-consumer tokens are NEVER committed:
# store only the lowercase sha256 of each raw bearer token here, supplied via
# the deployment's secret manager / environment. See
# docs/consumer-registry.example.json for the shape and how to generate hashes.
# Example (single line in real env):
# MCP_CONSUMER_REGISTRY=[{"id":"ops","token_sha256":"<sha256 of raw token>","defaultContract":"ops_operator","allowedContracts":["ops_operator"],"writeCapability":"false"}]
MCP_CONSUMER_REGISTRY=
