# WHMCS API Configuration
WHMCS_API_URL=https://your-whmcs-domain.com
WHMCS_IDENTIFIER=your_api_identifier
WHMCS_SECRET=your_api_secret
WHMCS_ACCESS_KEY=
# Set to true only to allow an http:// WHMCS_API_URL (not recommended; credentials sent in clear)
WHMCS_ALLOW_HTTP=false

# MCP Server Configuration
# Environment profile: local | staging | production (default: production).
# Selects which .env.<MCP_ENV> file is layered on top of this base .env.
# See .env.local.example for the local dockerized-WHMCS profile and
# docs/local-whmcs-testing.md for the full local dev/test workflow.
MCP_ENV=production
MCP_MODE=read_only
MCP_ACCESS_MODE=admin
MCP_ALLOWED_CLIENT_IDS=
MCP_AUTH_TOKEN=
MCP_RATE_LIMIT=10
MCP_DEBUG=false
MCP_MAX_PAGE_SIZE=100
MCP_TOOL_ALLOWLIST=
MCP_LARGE_REFUND_THRESHOLD=1000
