# WHMCS API Configuration
WHMCS_API_URL=https://your-whmcs-domain.com
WHMCS_IDENTIFIER=your_api_identifier
WHMCS_SECRET=your_api_secret
WHMCS_ACCESS_KEY=
# Set to true only to allow an http:// WHMCS_API_URL (not recommended; credentials sent in clear)
WHMCS_ALLOW_HTTP=false

# MCP Server Configuration
# Environment profile: local | staging | production (default: production).
# Selects which .env.<MCP_ENV> file is layered on top of this base .env.
# See .env.local.example for the local dockerized-WHMCS profile and
# docs/local-whmcs-testing.md for the full local dev/test workflow.
MCP_ENV=production
MCP_MODE=read_only
MCP_ACCESS_MODE=admin
MCP_ALLOWED_CLIENT_IDS=
MCP_AUTH_TOKEN=
MCP_RATE_LIMIT=10
MCP_DEBUG=false
MCP_MAX_PAGE_SIZE=100
MCP_TOOL_ALLOWLIST=
# Comma-separated id:label pairs for client custom fields (configured labels override WHMCS names)
MCP_CLIENT_CUSTOM_FIELD_LABELS=
MCP_LARGE_REFUND_THRESHOLD=1000

# ── Phase B governance (opt-in, backward compatible) ──────────────────────────
# OFF (default) => existing legacy tool/resource output is byte-identical
# (no app/test breakage). ON => read output is routed through the
# consumer-aware projection boundary. Production stays read-only either way.
MCP_GOVERNANCE_ENABLED=false
# Allow the deliberate anonymous llm_safe_summary fallback for unknown/no-token
# callers. NEVER grants a privileged profile; in production an explicit
# `anonymous` registry entry is still required. Default false.
MCP_ALLOW_ANON_LLM=false
# Consumer registry (JSON array). Real per-consumer tokens are NEVER committed:
# store only the lowercase sha256 of each raw bearer token here, supplied via
# the deployment's secret manager / environment. See
# docs/consumer-registry.example.json for the shape and how to generate hashes.
# Example (single line in real env):
# MCP_CONSUMER_REGISTRY=[{"id":"ops","token_sha256":"<sha256 of raw token>","defaultContract":"ops_operator","allowedContracts":["ops_operator"],"writeCapability":"false"}]
MCP_CONSUMER_REGISTRY=

# ── Tiered write governance ───────────────────────────────────────────────────
# Allowlist applies to HIGH-RISK scopes only; low/medium are audit-gated.
# Production write enablement (ALL default-sealed):
MCP_PROD_WRITE_AUTHORIZED=          # comma list of WHMCS actions OR write scopes; empty ⇒ high-risk prod sealed
MCP_WRITE_EXECUTION_AUTHORIZED=     # non-prod (dev/staging) runtime allowlist; empty ⇒ none
MCP_WRITE_KILL_SWITCH=false         # true ⇒ instantly seal all writes
MCP_PROD_HIGH_RISK_PER_ACTION_CAP=0 # money per-action cap (0 ⇒ high-risk money denied)
MCP_PROD_HIGH_RISK_DAILY_CAP=0      # money per-UTC-day cap
MCP_WRITE_AUDIT_PATH=               # JSONL durable audit (required once PROD_WRITE_AUTHORIZED non-empty)
MCP_WRITE_IDEMPOTENCY_PATH=         # JSONL durable idempotency ledger
# Tighten levers: force allowlist for ALL tiers, or for specific scopes.
MCP_WRITE_STRICT_ALLOWLIST=false
MCP_WRITE_STRICT_SCOPES=billing:invoice:create   # comma list; default gates invoice creation
# Re-expose the retired legacy direct-mutate write tools (default OFF ⇒ governed flow only).
MCP_ENABLE_LEGACY_WRITE_TOOLS=false

# ── Read cache (default OFF) ──────────────────────────────────────────────────
MCP_READ_CACHE_TTL_MS=0             # >0 enables; caches only static-ref reads
MCP_READ_CACHE_ACTIONS=GetTLDPricing,GetRegistrars,GetSupportDepartments,GetProducts,GetCurrencies

# ── Transport: stdio (default) | http (Streamable HTTP) ──────────────────────
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp
MCP_HTTP_ALLOWED_ORIGINS=           # comma list; empty ⇒ reject any present Origin (DNS-rebinding guard)
MCP_HTTP_MAX_SESSIONS=256
MCP_HTTP_SESSION_IDLE_MS=300000

# ── OAuth 2.1 resource-server (HTTP only; default OFF ⇒ registry bearer) ──────
# When ON: HTTP bearers are JWTs validated against the issuer(s) with
# aud == MCP_OAUTH_RESOURCE; a PRM doc is served at
# /.well-known/oauth-protected-resource. See docs/OAUTH_DESIGN.md.
MCP_OAUTH_ENABLED=false
MCP_OAUTH_RESOURCE=                 # this server's canonical resource URI (== expected token audience)
MCP_OAUTH_AUDIENCE=                 # defaults to MCP_OAUTH_RESOURCE if unset
MCP_OAUTH_ISSUERS=                  # comma list of trusted authorization-server issuer URLs
